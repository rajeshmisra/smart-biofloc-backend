const FishProfile = require('../models/FishProfile');

// Add Fish Profile
exports.addFishProfile = async (req, res) => {

    try {

        const profile = new FishProfile(req.body);

        await profile.save();

        res.status(201).json({
            message: 'Fish profile added successfully'
        });

    } catch (error) {

        res.status(500).json({
            error: error.message
        });

    }
};

// Get Latest Feeding Config
exports.getFeedingConfig = async (req, res) => {

    try {

        const config = await FishProfile.findOne().sort({ createdAt: -1 });

        res.json(config);

    } catch (error) {

        res.status(500).json({
            error: error.message
        });

    }
};
